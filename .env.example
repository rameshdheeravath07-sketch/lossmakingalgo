# Copy to .env and fill in your Dhan API credentials. NEVER commit the real .env.
DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_access_token

# Position sizing
CAPITAL_PER_TRADE=15000
MAX_TRADES_PER_DAY=4

# VWAP-cross strategy (validated config)
VWAP_CROSS_POINTS=80          # both 9 & 15 EMA this far from VWAP to enter
PROFIT_TARGET_PCT=0.5         # index % move profit target
HARD_STOP_PCT=0.7            # index % move stop
BREAKEVEN_TRIGGER_PCT=0.25   # arm break-even after this favorable move

# Session / exits
INTRADAY_ONLY=true           # square off same day
THETA_DECAY_PER_BAR=0.05

# Daily circuit breakers (0 = off)
DAILY_PROFIT_TARGET=0
DAILY_MAX_LOSS=0

# Slippage (Indian F&O charges are modelled precisely in the backtest)
SLIPPAGE_PCT=0.1
